# Публичный идентификатор OAuth-приложения truemail в Яндексе.
# client_secret для desktop-приложения не нужен и сюда не добавляется.
TRUEMAIL_YANDEX_CLIENT_ID=
# Зарегистрируйте этот точный Redirect URI в приложении Яндекс OAuth.
TRUEMAIL_YANDEX_REDIRECT_URI=http://127.0.0.1:34982/oauth/yandex/callback

# Публичный идентификатор Google OAuth Client типа Desktop app.
# Случайный loopback redirect создаётся самой программой. Google требует
# client_secret при обмене кода даже для Desktop app; он попадает в binary и
# поэтому не является секретом, который можно скрыть от владельца компьютера.
TRUEMAIL_GOOGLE_CLIENT_ID=
TRUEMAIL_GOOGLE_CLIENT_SECRET=
