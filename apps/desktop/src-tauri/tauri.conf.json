{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "truemail",
  "version": "0.1.7",
  "identifier": "ru.gitverse.chernov.truemail",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "truemail",
        "width": 1280,
        "height": 820,
        "minWidth": 640,
        "minHeight": 600,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: https: http:; frame-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDE1QzRCMTg5MjNBMDE5QTkKUldTcEdhQWppYkhFRmIyV1lJUlFjeUxxY0hsRklsaVh2bHdvMzBYM0VBbERrbVM2M2RiNXpLWEIK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
